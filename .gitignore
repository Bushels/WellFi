# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# dev/serve script logs (Next.js dev server, custom serve scripts)
dev-*.log
serve-*.log
start-*.log

# local browser-verification artifacts
.playwright-cli/
output/playwright/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
.env*.local

# OS artifacts
Thumbs.db
Desktop.ini

# editor / IDE
.vscode/
.idea/
*.swp
*~

# test outputs
/test-results/
/playwright-report/
/vitest-results/
/.nyc_output/

# stray dev/serve server logs (never commit)
dev-*.log
serve-*.log
start-*.log
/tmp/
